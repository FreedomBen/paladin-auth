<!--
  SPDX-License-Identifier: AGPL-3.0-or-later

  Paladin Auth GTK gresource bundle manifest. The `prefix` mirrors
  `paladin_auth_gtk::APP_ID` (`org.tamx.PaladinAuth.Gui`) so the resource
  pool namespaces by reverse-DNS app ID, and the entries listed
  below resolve at runtime under `/org/tamx/PaladinAuth/Gui/<file>`
  paths spelled by the `format_app_*_resource_path` helpers in
  `paladin_auth_gtk::app::model`. Build-time compilation happens in
  `build.rs` via `glib_build_tools::compile_resources`, which
  feeds this manifest to `glib-compile-resources` and emits the
  packed `paladin-auth-gtk.gresource` payload under `OUT_DIR` for
  `include_bytes!` to embed into the binary.

  The icon entry under `icons/scalable/actions/` follows the
  freedesktop icon-theme directory layout consumed by
  `gtk::IconTheme::add_resource_path`. Pairing the path with
  `wire_app_icon_theme_resource_path` lets the placeholder
  symbolic resolve identically in native and Flatpak builds even
  when the sandboxed runtime omits the system icon set.
-->
<gresources>
  <gresource prefix="/org/tamx/PaladinAuth/Gui">
    <file compressed="true" alias="style.css">style.css</file>
    <file compressed="true" alias="icons/scalable/actions/dialog-password-symbolic.svg">icons/scalable/actions/dialog-password-symbolic.svg</file>
    <!--
      App icon (colored + symbolic) bundled under the freedesktop
      `<root>/scalable/apps/<name>.svg` and
      `<root>/symbolic/apps/<name>-symbolic.svg` layout. With
      `wire_app_icon_theme_resource_path` attaching
      `/org/tamx/PaladinAuth/Gui/icons` to the live `gtk::IconTheme`,
      the in-app `IconTheme::lookup_icon(APP_ID, …)` resolves
      these payloads even when the system hicolor theme has not
      yet indexed the freshly installed PNG fallbacks — useful
      during `cargo run`, the `xvfb-run` smoke test, and Flatpak
      sandboxes whose runtime theme omits the package. The PNG
      fallbacks are not bundled because the gresource bundle is
      consumed only by the in-app icon-theme layer; PNG
      consumers (legacy panels, certain embedded launchers)
      always read from `/usr/share/icons/hicolor/<size>/apps/`.
    -->
    <file compressed="true" alias="icons/scalable/apps/org.tamx.PaladinAuth.Gui.svg">icons/hicolor/scalable/apps/org.tamx.PaladinAuth.Gui.svg</file>
    <file compressed="true" alias="icons/symbolic/apps/org.tamx.PaladinAuth.Gui-symbolic.svg">icons/hicolor/symbolic/apps/org.tamx.PaladinAuth.Gui-symbolic.svg</file>
    <!--
      Repo-root `LICENSE` (AGPL-3.0-or-later, FSF AGPLv3 verbatim
      text) shipped under `/org/tamx/PaladinAuth/Gui/LICENSE` so the
      §"About dialog" `AdwAboutDialog` can hand the bundled body
      to `set_license` (paired with
      `set_license_type(License::Custom)`) and bundle inspectors
      can resolve the project license by gresource path. The
      same source bytes are surfaced at compile time through
      `format_app_about_dialog_license_text` (`include_str!` on
      the same on-disk path) so the helper and the bundle stay
      consistent by construction. The workspace-root source dir
      is added by `build.rs` via
      `glib_build_tools::compile_resources(&["data", "../.."], ...)`
      so the relative path `LICENSE` resolves against the
      workspace root.
    -->
    <file compressed="true" alias="LICENSE">LICENSE</file>
  </gresource>
</gresources>
