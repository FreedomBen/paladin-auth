# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Paladin GTK desktop entry per IMPLEMENTATION_PLAN_04_GTK.md
# §"Linux desktop integration". This file installs verbatim at
# /usr/share/applications/org.tamx.Paladin.Gui.desktop in both the
# native (.deb / .rpm) and Flatpak packaging formats so the AppStream
# <launchable type="desktop-id">org.tamx.Paladin.Gui.desktop</launchable>
# reference resolves identically across packagings.
#
# Icon=, StartupWMClass=, and the AppStream <id> share the app ID
# org.tamx.Paladin.Gui (see paladin_gtk::APP_ID) so the icon-theme
# lookup, the window-to-launcher grouping, and the AppStream
# component reference all resolve identically.
[Desktop Entry]
Type=Application
Version=1.0
Name=Paladin
GenericName=Authenticator
Comment=One-time password authenticator for TOTP and HOTP accounts
Icon=org.tamx.Paladin.Gui
Exec=paladin-gtk
Terminal=false
StartupNotify=true
StartupWMClass=org.tamx.Paladin.Gui
Categories=Utility;Security;
Keywords=OTP;TOTP;HOTP;2FA;MFA;Authenticator;One-Time-Password;Two-Factor;Security;
